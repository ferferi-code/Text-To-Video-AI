# ==========================================
# LLM Provider Selection
# ==========================================
# Options: auto, openrouter, openai, groq, gemini
# "auto" = Smart fallback: tries openrouter -> gemini -> groq -> openai
LLM_PROVIDER=auto

# ==========================================
# LLM Model Configurations
# ==========================================
# OpenRouter Models (https://openrouter.ai/models)
OPENROUTER_MODEL=openai/gpt-4o
# Options: openai/gpt-4o, meta-llama/llama-3.3-70b-instruct, mistralai/mistral-large, 
#          qwen/qwen-2.5-72b-instruct, deepseek/deepseek-chat, openai/gpt-4o-mini

# OpenAI Models (https://platform.openai.com/docs/models)
OPENAI_MODEL=gpt-4o
# Options: gpt-4o, gpt-4o-mini, gpt-4-turbo, o1-mini, gpt-3.5-turbo

# Groq Models (https://console.groq.com/docs/models)
GROQ_MODEL=llama-3.3-70b-versatile
# Options: llama-3.3-70b-versatile, llama-3.1-70b-versatile, mixtral-8x7b-32768, 
#          gemma2-9b-it, llama-3.1-8b-instant

# Gemini Models (https://ai.google.dev/gemini-api/docs/models/gemini)
GEMINI_MODEL=gemini-1.5-flash
# Options: gemini-1.5-flash, gemini-1.5-pro, gemini-1.5-flash-8b, gemini-2.0-flash-exp

# ==========================================
# API Keys (Required based on LLM_PROVIDER)
# ==========================================
# Get your API keys from:
# - OpenRouter: https://openrouter.ai/keys (Free tier available)
# - OpenAI: https://platform.openai.com/api-keys (Paid)
# - Groq: https://console.groq.com/keys (Free tier available)
# - Gemini: https://aistudio.google.com/app/apikey (Free)

OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
GROQ_API_KEY=your_groq_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# ==========================================
# Video Source API Keys (At least one required)
# ==========================================
# Pexels: https://www.pexels.com/api/ (Free)
# Muapi: https://muapi.ai/ (Paid - AI Video Generation)

PEXELS_API_KEY=your_pexels_api_key_here
MUAPI_API_KEY=your_muapi_api_key_here

# ==========================================
# Muapi Configuration (Optional)
# ==========================================
MUAPI_BASE_URL=https://api.muapi.ai
# Video Generation Models:
# - Google Veo: veo3-fast-text-to-video, veo3-text-to-video, veo3.1-fast-text-to-video
# - xAI Grok: grok-imagine-text-to-video
# - ByteDance Seedance: sd-2-t2v, seedance-2-vip-text-to-video
# - Kling: kling-v3.0-pro-text-to-video, kling-v3.0-standard-text-to-video
# - OpenAI Sora: openai-sora-2-pro-text-to-video
MUAPI_VIDEO_MODEL=veo3-fast-text-to-video

# ==========================================
# Video Orientation
# ==========================================
# Options: portrait (vertical, 1080x1920) or landscape (horizontal, 1920x1080)
# Portrait is recommended for YouTube Shorts, Instagram Reels, and TikTok
VIDEO_ORIENTATION=portrait

# ==========================================
# Speech-to-Text Provider
# ==========================================
# Options: whisper (Free, local) or deepgram (Paid, cloud-based)
STT_PROVIDER=whisper

# Deepgram Configuration (Required if STT_PROVIDER=deepgram)
# Get your API key from: https://deepgram.com/
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# ==========================================
# Text-to-Speech Provider
# ==========================================
# Options: edgetts (Free) or elevenlabs (Paid, premium quality)
TTS_PROVIDER=edgetts

# EdgeTTS Voice Configuration (Required if TTS_PROVIDER=edgetts)
# English voices:
#   en-US-GuyNeural (American male)
#   en-US-JennyNeural (American female)
#   en-GB-SoniaNeural (British female)
#   en-GB-RyanNeural (British male)
#   en-AU-WilliamNeural (Australian male)
# Persian voices:
#   fa-IR-FaridNeural (Persian male)
#   fa-IR-DilaraNeural (Persian female)
EDGETTS_VOICE=en-US-GuyNeural

# ElevenLabs Configuration (Required if TTS_PROVIDER=elevenlabs)
# Get your API key from: https://elevenlabs.io/
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=your_elevenlabs_voice_id_here
# Popular Voice IDs:
#   "21m00Tcm4TlvDq8ikWAM" (Adam - American male)
#   "AZnzlk1XvdvUeBnXmlld" (Domi - American female)
#   "EXAVITQu4vr4xnSDxMaL" (Bella - American female)

# ==========================================
# Caption Configuration
# ==========================================
CAPTIONS_ENABLED=true           # Enable or disable captions (true/false)

# Caption Style Options: hormozi, card, neon, minimal, karaoke, comic
CAPTION_STYLE=hormozi
# Caption Styling (only applies when CAPTIONS_ENABLED=true)
CAPTION_FONT_SIZE=100           # Font size (higher = bigger text)
CAPTION_FONT_COLOR=yellow       # Text color (white, yellow, cyan, red, green, blue, magenta)
CAPTION_FONT_FACE=Arial-Bold    # Font face (Arial-Bold, Helvetica, Roboto-Bold, Impact, Courier-New)
CAPTION_STROKE_WIDTH=4          # Stroke/outline width (higher = thicker outline)
CAPTION_STROKE_COLOR=black      # Stroke/outline color
CAPTION_POSITION=bottom_center  # Position: center, top, bottom, bottom_center, bottom_left, bottom_right

# ==========================================
# Render Engine Configurations
# ==========================================
# Options: moviepy (legacy/fast, Python-based) or remotion (React-based, advanced)
RENDER_ENGINE=moviepy

# Remotion Theme (only if RENDER_ENGINE=remotion)
# Options: clean-professional, flat-motion-graphics, minimalist-diagram, anime-ghibli
REMOTION_THEME=flat-motion-graphics
